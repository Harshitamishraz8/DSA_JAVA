class Solution {
    public boolean check(int[] nums) {
        // intution is that a rotated sorted array can break only once
        int l=nums.length;
        int j=0;
        for(int i=0; i<l; i++)
        {
            if(nums[i]>nums[(i+1)%l])
            {
                j++;
            }
            if(j>=2) return false;
        }
        return true;
    }
}
